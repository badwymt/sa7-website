{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/category/layout,_N_T_/category/[id]/layout,_N_T_/category/[id]/page,_N_T_/category/snacks"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/category/$d$id/__PAGE__",
    "/category/$d$id",
    "/category",
    "/_index",
    "/_head"
  ]
}